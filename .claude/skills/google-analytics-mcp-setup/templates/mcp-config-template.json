{
  "mcpServers": {
    "google-analytics": {
      "command": "{{PYTHON_PATH}}",
      "args": [
        "-m",
        "pipx",
        "run",
        "--spec",
        "git+https://github.com/googleanalytics/google-analytics-mcp.git",
        "google-analytics-mcp"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "{{CREDENTIALS_PATH}}",
        "GOOGLE_CLOUD_PROJECT": "{{PROJECT_ID}}"
      }
    }
  }
}
